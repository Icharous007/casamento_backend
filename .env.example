# =====================================================================
# Casamento Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =====================================================================

# Quarkus Profile (dev | test | prod)
QUARKUS_PROFILE=dev

# ── Banco de Dados ──────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/casamento
DB_USERNAME=casamento
DB_PASSWORD=casamento

# ── JWT ─────────────────────────────────────────────────────────────
# Em dev: usar make generate-keys para gerar as chaves RSA
JWT_ISSUER=https://casamento.local
JWT_PUBLIC_KEY_LOCATION=META-INF/resources/publicKey.pem
JWT_PRIVATE_KEY_LOCATION=META-INF/resources/privateKey.pem

# ── Email (Resend SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_FROM=noreply@seudominio.com.br
SMTP_USERNAME=resend
SMTP_PASSWORD=re_XXXXXXXXXXXXXXXX

# ── Cloudflare R2 ───────────────────────────────────────────────────
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=casamento-media
R2_REGION=auto

# ── Aplicação ───────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173
APP_TIMEZONE=America/Sao_Paulo
APP_CONFIRMATION_PHRASE=APAGAR EVENTO

# ── Limites de Email ────────────────────────────────────────────────
EMAIL_DAILY_LIMIT=100
EMAIL_BATCH_SIZE=50
EMAIL_MAX_RETRIES=3

# ── Rate Limiting ───────────────────────────────────────────────────
RATE_LIMIT_GUEST_RESOLVE=10
RATE_LIMIT_ADMIN_LOGIN=10
RATE_LIMIT_FORGOT_PASSWORD=5

# ── Jobs (DEV/TEST only — prod usa IAM/OIDC) ────────────────────────
JOB_SECRET=dev-job-secret-change-in-prod

# ── CORS (prod only) ────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://seudominio.vercel.app

# ── Google Cloud (prod) ─────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=seu-project-id
